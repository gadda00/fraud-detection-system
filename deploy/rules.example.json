{
  "rules": [
    {
      "id": "high_value_offshore_block",
      "description": "Block transactions > $10,000 to known offshore tax havens",
      "match": {
        "amount_min": 10000,
        "countries": ["KY", "VG", "BZ", "PA", "BM", "LI", "MC"]
      },
      "action": "block",
      "weight": 1.0
    },
    {
      "id": "high_value_review",
      "description": "Force manual review for transactions > $5,000",
      "match": {
        "amount_min": 5000
      },
      "action": "review"
    },
    {
      "id": "crypto_exchange_flag",
      "description": "Flag transactions at cryptocurrency exchanges",
      "match": {
        "merchants": ["cryptoexchange", "cryptowallet", "mixer-service"]
      },
      "action": "flag",
      "weight": 0.5
    },
    {
      "id": "gambling_flag",
      "description": "Flag transactions at offshore gambling sites",
      "match": {
        "merchants": ["offshorebets", "casino", "betting"]
      },
      "action": "flag",
      "weight": 0.4
    },
    {
      "id": "sanctioned_countries_block",
      "description": "Block transactions to sanctioned countries",
      "match": {
        "countries": ["CU", "IR", "KP", "SY"]
      },
      "action": "block",
      "weight": 1.0
    },
    {
      "id": "high_value_travel_flag",
      "description": "Flag high-value travel transactions to non-US countries",
      "match": {
        "amount_min": 1000,
        "categories": ["travel"],
        "exclude_countries": ["US"]
      },
      "action": "flag",
      "weight": 0.6
    },
    {
      "id": "known_fraud_device_block",
      "description": "Block transactions from devices on the known-fraud list",
      "match": {
        "device_ids": ["dev-known-fraud-1", "dev-known-fraud-2"]
      },
      "action": "block",
      "weight": 1.0
    }
  ]
}
